# web/ env: loaded by Vite (astro dev / build) for PUBLIC_* and merged into the Node server via loadAllAppEnv().
# Prefer API secrets in the repo root .env.local; values here override root when you run server.js or web/run-server.mjs.

# Split hosting (production build):
# PUBLIC_APP_BASE=https://your-api.example.com

# Full stack (`cd web && npm start`): run-server.mjs sets ASTRO_NODE_AUTOSTART=disabled so Astro
# does not open a second server on localhost:PORT (that caused POST /api/run 403 for IPv6 "localhost").

# Local `astro dev` (fixes many 403s on Start audit — Vite’s proxy mishandles multipart POST).
# When set, this wins over PUBLIC_APP_BASE in dev so you can keep a production URL in .env.
# Use the SAME hostname you use in the browser (localhost vs 127.0.0.1 vs ::1).
# PUBLIC_DEV_API_URL=http://localhost:3456
# RELAX_CORS_LOCALHOST=true
