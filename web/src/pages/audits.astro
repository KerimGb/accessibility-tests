---
import Layout from '../layouts/Layout.astro';
import AppHeader from '../components/AppHeader.astro';
---
<Layout title="All domain audits · Us">
  <div class="app-shell">
    <AppHeader crumb="All audits" />
    <main class="app-main">
      <div data-screen-label="All audits" style="background: var(--us-cream); min-height: calc(100vh - 65px); position: relative; overflow: hidden;">
        <div aria-hidden="true" style="position: absolute; top: -180px; right: -120px; width: 520px; height: 520px; border-radius: 50%; background: var(--us-grad-iridescent); opacity: 0.35; filter: blur(60px); animation: drift 24s ease-in-out infinite; pointer-events: none;"></div>

        <div class="container" style="padding: 56px 32px 96px; position: relative;">
          <div class="audits-head">
            <div>
              <span class="eyebrow"><span class="dot"></span>Audits archive · /audits</span>
              <h1 class="audits-title">All domain audits</h1>
              <p class="p-large muted" style="max-width: 680px;">
                One row per domain — open the latest report or browse the full history of runs.
              </p>
            </div>
            <a class="btn btn-primary btn-lg" href="/">
              Run new audit
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
            </a>
          </div>

          <div class="card-flat" style="padding: 22px; margin-bottom: 24px;">
            <p class="muted" style="font-size: 14px; margin: 0 0 12px;">
              Audits are protected. Enter the app password (or <a class="link" href="/auth/login?next=/audits">sign in</a>) to load the list.
            </p>
            <div style="display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap;">
              <div class="field" style="flex: 1; min-width: 240px; max-width: 360px;">
                <label class="field-label" for="pwd">App password</label>
                <input class="input" id="pwd" type="password" autocomplete="current-password" />
              </div>
              <button type="button" class="btn btn-primary" id="load">Load audits</button>
            </div>
            <div id="msg" style="margin-top: 10px; font-size: 14px; color: var(--us-peach-text); min-height: 20px;"></div>
          </div>

          <div class="card-flat" style="padding: 0;" id="list-wrap">
            <div class="list-row audits-row head">
              <span>Domain</span>
              <span>Latest run</span>
              <span>Status</span>
              <span>Pages</span>
              <span>Issues</span>
              <span>Runs</span>
              <span>Updated</span>
              <span></span>
            </div>
            <div id="rows">
              <div class="list-row audits-row" style="grid-template-columns: 1fr;">
                <span class="muted" style="text-align: center; padding: 8px 0;">Click "Load audits" to see the archive.</span>
              </div>
            </div>
          </div>

          <p class="muted" style="font-size: 12px; margin-top: 18px; text-align: center;">
            Every domain has a permanent URL: <span class="mono">/report/&lt;domain&gt;/history</span>. Each run lives at <span class="mono">/report/&lt;domain&gt;/&lt;runId&gt;/</span>.
          </p>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  const pwdEl = document.getElementById('pwd') as HTMLInputElement | null;
  const rowsEl = document.getElementById('rows') as HTMLDivElement | null;
  const msgEl = document.getElementById('msg') as HTMLDivElement | null;
  const loadBtn = document.getElementById('load') as HTMLButtonElement | null;

  function escapeHtml(s: unknown): string {
    return String(s ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function formatDate(value: unknown): string {
    if (!value) return '—';
    const d = new Date(value as string);
    if (Number.isNaN(d.getTime())) return '—';
    return d.toLocaleString('en-CA', { dateStyle: 'medium', timeStyle: 'short' });
  }

  function formatRunId(runId: string): string {
    return runId.replace(/Z-[0-9a-f]+$/, 'Z');
  }

  function statusTag(status: string): string {
    const s = String(status || '').toLowerCase();
    if (s === 'done' || s === 'completed') return '<span class="tag tag-success">done</span>';
    if (s === 'running' || s === 'pending') return '<span class="tag tag-warning">' + escapeHtml(status) + '</span>';
    if (s === 'error' || s === 'failed') return '<span class="tag tag-error">' + escapeHtml(status) + '</span>';
    return '<span class="tag">' + escapeHtml(status || 'unknown') + '</span>';
  }

  loadBtn?.addEventListener('click', async () => {
    if (!msgEl || !rowsEl) return;
    msgEl.textContent = '';
    const p = pwdEl?.value?.trim() || '';
    const url = '/api/audits' + (p ? '?password=' + encodeURIComponent(p) : '');
    const headers: Record<string, string> = {};
    if (p) headers['X-App-Password'] = p;
    rowsEl.innerHTML = '<div class="list-row audits-row" style="grid-template-columns: 1fr;"><span class="muted" style="text-align: center; padding: 8px 0;">Loading…</span></div>';
    try {
      const res = await fetch(url, { headers, credentials: 'same-origin' });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        msgEl.textContent = data.error || 'Failed to load';
        rowsEl.innerHTML = '';
        return;
      }
      const audits = (data.audits || []) as Array<{
        id: string;
        domain?: string;
        latestRunId?: string;
        status: string;
        pages?: number;
        issues?: number;
        totalRuns?: number;
        updatedAt?: string | null;
      }>;
      if (!audits.length) {
        rowsEl.innerHTML = '<div class="list-row audits-row" style="grid-template-columns: 1fr;"><span class="muted" style="text-align: center; padding: 8px 0;">No audits yet — start your first run from the home page.</span></div>';
        return;
      }
      rowsEl.innerHTML = audits
        .map((a) => {
          const domain = a.domain || a.id;
          const pq = p ? '?password=' + encodeURIComponent(p) : '';
          const latestRunId = a.latestRunId || '';
          const reportHref = latestRunId
            ? `/report/${encodeURIComponent(domain)}/${encodeURIComponent(latestRunId)}/${pq}`
            : `/report/${encodeURIComponent(domain)}/${pq}`;
          const historyHref = `/report/${encodeURIComponent(domain)}/history${pq}`;
          const totalRuns = Number(a.totalRuns || 1);
          return `<div class="list-row audits-row">
            <a class="link" style="font-weight: 500; text-decoration: none; color: var(--fg-1);" href="${historyHref}">
              <strong>${escapeHtml(domain)}</strong>
            </a>
            <span class="mono" style="font-size: 12px;">${escapeHtml(latestRunId ? formatRunId(latestRunId) : '—')}</span>
            <span>${statusTag(a.status)}</span>
            <span class="muted mono" style="font-size: 12px;">${Number(a.pages || 0)}</span>
            <span class="tag tag-error">${Number(a.issues || 0)}</span>
            <span style="font-weight: 600; font-variant-numeric: tabular-nums;">${totalRuns}</span>
            <span class="muted" style="font-size: 12px;">${escapeHtml(formatDate(a.updatedAt))}</span>
            <span style="display: flex; gap: 6px; justify-content: flex-end;">
              <a class="btn btn-cream btn-sm" href="${reportHref}">Open</a>
              <a class="btn btn-secondary btn-sm" href="${historyHref}">History (${totalRuns})</a>
            </span>
          </div>`;
        })
        .join('');
    } catch {
      msgEl.textContent = 'Network error';
      rowsEl.innerHTML = '';
    }
  });

  // Auto-load if a session cookie is already present (so login flow lands here).
  setTimeout(() => loadBtn?.click(), 0);
</script>

<style>
  .audits-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: flex-end;
    margin-bottom: 28px;
  }
  .audits-title {
    font-size: clamp(36px, 4.5vw, 56px);
    margin-top: 12px;
    margin-bottom: 10px;
  }
  .audits-row {
    grid-template-columns: 1.4fr 1fr 100px 80px 90px 70px 1.2fr 220px;
    align-items: center;
    gap: 12px;
  }
  .audits-row.head {
    background: var(--us-n-20);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-3);
    font-weight: 600;
  }
  .audits-row + .audits-row {
    border-top: 1px solid var(--border-subtle);
  }
  @media (max-width: 980px) {
    .audits-head { grid-template-columns: 1fr; }
    .audits-row { grid-template-columns: 1fr; }
    .audits-row.head { display: none; }
  }
</style>
