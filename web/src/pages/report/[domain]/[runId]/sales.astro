---
import Layout from '../../../../layouts/Layout.astro';
import AppHeader from '../../../../components/AppHeader.astro';
import SalesDeck from '../../../../components/SalesDeck.svelte';
import { readFileSync, existsSync } from 'node:fs';
import { join } from 'node:path';
import { buildAstroMainReportPayload } from '../../../../../../report-astro-payload.js';
import { isValidReportId } from '../../../../../../server/fs-utils.js';
import { runDir, isValidRunId } from '../../../../../../server/run-ids.js';
import { listRunsForDomain } from '../../../../../../server/audit-list.js';
import { dbPool } from '../../../../../../server/db.js';
import { REPORTS_BASE } from '../../../../../../server/paths.js';
import { getSamplePrinciples } from '../../../../lib/sample-buckets';

export const prerender = false;

const rawDomain = Astro.params.domain ?? '';
const rawRunId = Astro.params.runId ?? '';
const domain = typeof rawDomain === 'string' ? rawDomain : String(rawDomain);
const runId = typeof rawRunId === 'string' ? rawRunId : String(rawRunId);

if (!isValidReportId(domain) || !isValidRunId(runId)) {
  return new Response('Invalid run id', { status: 400 });
}

const reportDir = runDir(domain, runId);
const resultsPath = join(reportDir, 'accessibility-results.json');
if (!existsSync(resultsPath)) {
  return new Response('Report not found', { status: 404 });
}

const json = JSON.parse(readFileSync(resultsPath, 'utf8'));
const payload = buildAstroMainReportPayload(json);

const statementMetaPath = join(reportDir, 'statement-meta.json');
let statementMeta: any = null;
try {
  if (existsSync(statementMetaPath)) {
    statementMeta = JSON.parse(readFileSync(statementMetaPath, 'utf8'));
  }
} catch {}

const principles = getSamplePrinciples({
  errors: payload.severityCounts.errors,
  warnings: payload.severityCounts.warnings,
  passed: payload.severityCounts.passed,
});

const allRuns = await listRunsForDomain(dbPool, REPORTS_BASE, domain);
const trend = allRuns
  .slice()
  .reverse()
  .filter((r) => typeof r.score === 'number')
  .map((r) => {
    const d = r.updatedAt ? new Date(r.updatedAt) : null;
    const label = d && !Number.isNaN(d.getTime())
      ? d.toLocaleString('en-GB', { month: 'short', day: '2-digit' })
      : r.runId.slice(5, 10);
    return { date: label, score: r.score as number };
  });
const previousScore = (() => {
  const idx = allRuns.findIndex((r) => r.runId === runId);
  if (idx < 0) return null;
  const prev = allRuns[idx + 1];
  return prev && typeof prev.score === 'number' ? prev.score : null;
})();

const fixOrderTopColors = ['var(--us-peach)', 'var(--us-lilac)', 'var(--us-mint)', 'var(--us-sky)', 'var(--us-pink)'];
const topFixes = (payload.fixOrderTop || []).slice(0, 5).map((f, i) => ({
  rank: String(i + 1).padStart(2, '0'),
  title: f.rule || f.id || 'Fix',
  impact: f.snippet || `Affects ${f.url || 'multiple pages'}.`,
  points: typeof f.effort === 'number' ? f.effort : f.impact === 'High' ? 5 : f.impact === 'Medium' ? 3 : 1,
  color: fixOrderTopColors[i % fixOrderTopColors.length],
}));

const companyName = statementMeta?.organizationName || statementMeta?.organizationShortName || payload.primaryHost;
const legalName = statementMeta?.organizationName || '';
const coordinator = statementMeta?.contactName || statementMeta?.coordinator || '';
const coordinatorEmail = statementMeta?.contactEmail || statementMeta?.email || '';

const deckProps = {
  primaryHost: payload.primaryHost,
  companyName,
  auditDate: payload.auditedDate,
  scoreClamp: payload.scoreClamp,
  previousScore,
  pagesScanned: payload.urls.length,
  rulesChecked: payload.rulesTable.length,
  trend: trend.length > 1 ? trend : [
    { date: 'now', score: payload.scoreClamp },
  ],
  principles,
  topFixes,
  coordinator,
  coordinatorEmail,
  legalName,
  domain,
  runId,
};
---

<Layout title={`Sales report · ${companyName}`}>
  <div class="app-shell">
    <AppHeader domain={domain} runId={runId} active="sales" />
    <main class="app-main">
      <SalesDeck client:only="svelte" {...deckProps} />
    </main>
  </div>
</Layout>

<script src="/vendor/deck-stage.js" is:inline></script>
