---
import LoginModal from '../components/LoginModal.astro';

interface Props {
  title?: string;
}
const { title = 'Accessibility audit · Us' } = Astro.props;
const publicAppBase = import.meta.env.PUBLIC_APP_BASE?.trim() ?? '';
const devApiBase =
  import.meta.env.DEV && (import.meta.env.PUBLIC_DEV_API_URL?.trim() ?? '')
    ? import.meta.env.PUBLIC_DEV_API_URL.trim()
    : '';
/** In dev, prefer direct API URL so multipart POST skips Vite proxy; production still uses PUBLIC_APP_BASE. */
const appBaseMeta =
  import.meta.env.DEV && devApiBase ? devApiBase : publicAppBase || devApiBase;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex" />
    <title>{title}</title>
    {appBaseMeta ? <meta name="accessibility-app-base" content={appBaseMeta} /> : null}
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='14' fill='%2319191B'/%3E%3C/svg%3E" />
    <link rel="stylesheet" href="/styles/tokens.css" />
    <link rel="stylesheet" href="/styles/app.css" />
  </head>
  <body>
    <script is:inline>
      (function () {
        var m = document.querySelector('meta[name="accessibility-app-base"]');
        var base = (m && m.getAttribute('content')) ? m.getAttribute('content').trim().replace(/\/$/, '') : '';
        globalThis.wcagApiUrl = function (path) {
          var p = path.charAt(0) === '/' ? path : '/' + path;
          if (!base) return p;
          if (/^https?:\/\//i.test(base)) return base + p;
          return base + p;
        };
        globalThis.wcagFetchCredentials = function () {
          if (!base) return 'same-origin';
          if (/^https?:\/\//i.test(base)) return 'include';
          return 'same-origin';
        };
      })();
    </script>
    <div id="wcag-main" class="wcag-main-shell" hidden inert>
      <slot />
    </div>
    <div id="wcag-session-bar" class="wcag-session-bar" hidden>
      <button type="button" id="wcag-logout-btn" class="wcag-session-logout" aria-label="Log out">
        Log out
      </button>
    </div>
    <LoginModal />
    <noscript>
      <div class="wcag-noscript">Enable JavaScript to sign in and use this app.</div>
    </noscript>
    <style is:global>
      .wcag-session-bar {
        position: fixed;
        top: 0;
        right: 0;
        z-index: 99900;
        padding: 12px 16px;
        pointer-events: auto;
      }
      .wcag-session-logout {
        font-family: var(--font-body, 'Public Sans', system-ui, sans-serif);
        font-size: 0.875rem;
        font-weight: 600;
        padding: 8px 14px;
        border-radius: 10px;
        border: 1px solid rgba(25, 25, 27, 0.12);
        background: rgba(255, 255, 255, 0.85);
        color: var(--fg-1, #19191b);
        cursor: pointer;
        box-shadow: 0 2px 10px rgba(25, 25, 27, 0.06);
      }
      .wcag-session-logout:hover {
        filter: brightness(0.97);
        border-color: rgba(25, 25, 27, 0.2);
      }
      .wcag-session-logout:focus-visible {
        outline: 2px solid var(--focus-ring, #6257e8);
        outline-offset: 2px;
      }
      .wcag-noscript {
        position: fixed;
        inset: 0;
        z-index: 100000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: var(--us-cream, #f5f4e5);
        font-family: var(--font-body, system-ui, sans-serif);
        font-size: 1rem;
        color: var(--fg-1, #19191b);
      }
    </style>
  </body>
</html>
